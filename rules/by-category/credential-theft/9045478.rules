alert tcp $HOME_NET any -> any any (msg:"OPSWAT Nexus Forge - SSA-523250 V1.0: Improper Certificate Validation Vulnerability in SINUMERIK Edge T1557"; flow:to_server,established; tls.sni; content:"SINUMERIK-Edge"; nocase; fast_pattern; pcre:"/^CN=.*SINUMERIK.*(Self-Signed|Unknown)/i"; classtype:credential-theft; metadata:created_at 2026-05-05, signature_severity high, affected_product SSA-523250_V1.0:_Improper_Certificate_Validation_Vulnerability_in_SINUMERIK_Edge, attack_target Credential_Access, deployment perimeter, mitre_technique T1557, mitre_tactic credential-access, author OPSWAT_Nexus_Forge, category credential-access, confidence high; sid:9045478; rev:1;)
