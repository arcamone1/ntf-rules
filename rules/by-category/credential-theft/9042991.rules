alert tcp $HOME_NET any -> any any (msg:"OPSWAT Nexus Forge - SSA-669158 V1.0: DNS Client Vulnerabilities in SIMOTICS CONNECT 400 T1557"; flow:to_server,established; dns.query; content:"simotics.connect"; nocase; fast_pattern; pcre:"/^[a-z0-9\-]{10,}\.simotics\.connect$/"; threshold:type limit,track by_src,count 10,seconds 60; classtype:credential-theft; metadata:created_at 2026-05-04, signature_severity high, affected_product SSA-669158_V1.0:_DNS_Client_Vulnerabilities_in_SIMOTICS_CONNECT_400, attack_target Credential_Access, deployment perimeter, mitre_technique T1557, mitre_tactic credential-access, author OPSWAT_Nexus_Forge, category credential-access, confidence high; sid:9042991; rev:1;)
