alert tls $HOME_NET any -> $EXTERNAL_NET 443 (msg:"OPSWAT Nexus Forge - Ransomware: safepay claimed maiadouro.pt T1573.002"; flow:to_server,established; tls.sni; content:"c2.maiadouro.pt"; nocase; fast_pattern; tls.cert_subject; content:"SafePay Ransomware CA"; nocase; pcre:"/^[a-z0-9\-]{5,}\.maiadouro\.pt$/"; threshold:type limit,track by_src,count 3,seconds 60; classtype:trojan-activity; metadata:created_at 2026-05-04, signature_severity high, affected_product Ransomware:_safepay_claimed_maiadouro.pt, attack_target Command_And_Control, deployment perimeter, mitre_technique T1573.002, mitre_tactic command-and-control, author OPSWAT_Nexus_Forge, category c2, confidence high; sid:9043423; rev:1;)
