alert tcp $HOME_NET any -> any any (msg:"OPSWAT Nexus Forge - SSA-412672 V1.0: Multiple OpenSSL and OpenSSH Vulnerabilities in SCALANCE X-200R T1071.002"; flow:to_server,established; ssh.softwareversion; content:"SSH-2.0-MalwareClient"; nocase; fast_pattern; pcre:"/^SSH-2\.0-[a-zA-Z0-9]{6,}-[Mm]alware.*/"; threshold:type limit,track by_src,count 3,seconds 60; classtype:trojan-activity; metadata:created_at 2026-05-04, signature_severity high, affected_product SSA-412672_V1.0:_Multiple_OpenSSL_and_OpenSSH_Vulnerabilities_in_SCALANCE_X-200R, attack_target Command_And_Control, deployment perimeter, mitre_technique T1071.002, mitre_tactic command-and-control, author OPSWAT_Nexus_Forge, category c2, confidence high; sid:9042611; rev:1;)
